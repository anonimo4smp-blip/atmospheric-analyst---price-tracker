APP_ENV=dev

POSTGRES_USER=admin
POSTGRES_PASSWORD=supersecreto
APP_DB_NAME=pricetracker
N8N_DB_NAME=n8n
POSTGRES_HOST_PORT=5433
BACKEND_HOST_PORT=8001
FRONTEND_HOST_PORT=5174

TIMEZONE=Europe/Madrid
VITE_API_BASE_URL=http://localhost:8001
CORS_ALLOW_ORIGINS=http://localhost:5174
CORS_ALLOW_CREDENTIALS=true

INTERNAL_API_KEY=change-this-key
# Email del usuario por defecto (owner bootstrap en fase 1).
ALERT_EMAIL=you@example.com
AUTH_JWT_SECRET=change-me-super-secret
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_EMAIL_TOKEN_TTL_HOURS=24
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_ENABLE_DEBUG_TOKENS=true
# Si es true, /api/products y /api/jobs/check-now requieren sesion.
AUTH_REQUIRE_LOGIN_FOR_APP=true
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_MINUTES=15
AUTH_RECOVERY_MAX_ATTEMPTS=5
AUTH_RECOVERY_WINDOW_MINUTES=15
AUTH_EMAIL_SEND_ENABLED=false
AUTH_EMAIL_SMTP_HOST=smtp.gmail.com
AUTH_EMAIL_SMTP_PORT=587
AUTH_EMAIL_SMTP_USER=
AUTH_EMAIL_SMTP_PASS=
AUTH_EMAIL_SMTP_SENDER=no-reply@example.com
AUTH_EMAIL_SMTP_USE_TLS=true
AUTH_EMAIL_SMTP_USE_SSL=false
AUTH_EMAIL_TIMEOUT_SECONDS=15
AUTH_EMAIL_VERIFY_URL_TEMPLATE=http://localhost:5174/?verify_token={token}
AUTH_EMAIL_RESET_URL_TEMPLATE=http://localhost:5174/?reset_token={token}
SECURITY_CSRF_ENABLED=true
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=false
SCRAPER_TIMEOUT_MS=35000
SCRAPER_MAX_RETRIES=2
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36
SCRAPER_ACCEPT_LANGUAGE=es-ES,es;q=0.9,en;q=0.8
SCRAPER_PROXY_SERVER=
SCRAPER_PROXY_USERNAME=
SCRAPER_PROXY_PASSWORD=

N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_HOST_PORT=5679
N8N_ENCRYPTION_KEY=replace-me

N8N_SMTP_HOST=smtp.gmail.com
N8N_SMTP_PORT=587
N8N_SMTP_USER=
N8N_SMTP_PASS=
N8N_SMTP_SENDER=
